---
import '../styles/global.css';
import '@fontsource-variable/geist/wght.css';
import { SEO } from 'astro-seo';
import type { SEOProps } from 'astro-seo';

interface Props extends Omit<SEOProps, 'title' | 'description'> {
    title: string;
    description?: string;
}

const { title, description, ...seoProps } = Astro.props;
const resolvedDescription = description ?? "Professional web design and development for UK businesses. Custom websites and landing pages built to help you grow online.";
---

<!doctype html>
<html lang="en-GB">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <SEO
        title={title}
        description={resolvedDescription}
        {...seoProps}
    />

    <link rel="sitemap" href="/sitemap-index.xml">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <script
        is:inline
        defer
        data-domain="cmwebsolutions.com"
        src="https://plausible.io/js/script.js"
    ></script>
    <script is:inline type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "Custom Made Web Solutions",
            "url": "https://www.cmwebsolutions.com",
            "logo": "https://www.cmwebsolutions.com/Logo.svg",
            "contactPoint": {
                "@type": "ContactPoint",
                "telephone": "+4403302296586",
                "contactType": "customer service"
            },
            "sameAs": [
                "https://www.linkedin.com/company/custom-made-web-solutions/"
            ]
        }
    </script>
</head>

<body>
    <slot />
</body>
</html>
