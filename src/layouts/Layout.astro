---
interface Props {
    title: string;
}

const {title} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8"/>
    <meta name="description"
          content="Providing professional web design and development services for growing busineses that are looking to improve their digital presence."/>
    <meta name="viewport" content="width=device-width"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <meta name="generator" content={Astro.generator}/>
    <script
            is:inline
            defer
            data-domain="cmwebsolutions.com"
            src="https://plausible.io/js/script.js"
    >

    </script>
    <script is:inline defer src="https://unpkg.com/flowbite@2.5.1/dist/flowbite.min.js"></script>

<script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "s77rswmzul");
</script>

    <title>{title}</title>

    <style is:inline>
        /* Vertical marquee animations (reused) */
        @keyframes marquee-vert-up {
            0% { transform: translateY(0); }
            100% { transform: translateY(-50%); }
        }
        @keyframes marquee-vert-down {
            0% { transform: translateY(-50%); }
            100% { transform: translateY(0); }
        }
        @layer utilities {
            .animate-marquee-vert-up   { animation: marquee-vert-up var(--duration, 26s) linear infinite; will-change: transform; }
            .animate-marquee-vert-down { animation: marquee-vert-down var(--duration, 26s) linear infinite; will-change: transform; }
        }
        @media (prefers-reduced-motion: reduce) {
            .animate-marquee-vert-up, .animate-marquee-vert-down { animation: none !important; }
        }
    </style>
</head>
<body class="bg-white text-gray-900 antialiased dark:bg-gray-950 dark:text-gray-100">
	<slot/>

    <script is:inline>
        // simple current year
        document.getElementById('year').textContent = new Date().getFullYear();
    </script>
</body>
</html>
