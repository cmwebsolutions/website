---
import '../styles/global.css';

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content="Professional subscription websites for UK businesses from £149/month. Zero upfront build cost. Design, hosting, maintenance, support and SEO setup included." />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <script
        is:inline
        defer
        data-domain="cmwebsolutions.com"
        src="https://plausible.io/js/script.js"
    ></script>
</head>

<body>
    <slot />
</body>
</html>
