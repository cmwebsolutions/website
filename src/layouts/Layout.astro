---
import '../styles/global.css';
import '@fontsource-variable/geist/wght.css';

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content="Professional managed websites for UK businesses. £499 one-off setup, then £249/month. Design, hosting, SSL, backups, maintenance and support included." />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <script
        is:inline
        defer
        data-domain="cmwebsolutions.com"
        src="https://plausible.io/js/script.js"
    ></script>
</head>

<body>
    <slot />
</body>
</html>
