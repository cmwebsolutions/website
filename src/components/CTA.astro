---
interface Props {
    eyebrow?: string;
    heading?: string;
    description?: string;
    formId?: string;
    dropdownType?: 'business' | 'package';
}

const {
    eyebrow = "Free consultation",
    heading = "Ready to get started on your website?",
    description = "Tell us about your project and we'll put together a custom proposal. No obligation, just a friendly chat.",
    formId = "mlgydvbn",
    dropdownType = "business"
} = Astro.props;

const formElementId = `cta-form-${formId.replace(/[^a-zA-Z0-9]/g, '-')}`;
---

<section class="cta" id="consultation">
    <div class="container">
        <div class="cta-panel">
            <div>
                <span class="eyebrow">{eyebrow}</span>
                <h2>{heading}</h2>
                <p class="lead">{description}</p>
            </div>

            <div data-fs-success>
                <strong>Thanks for your enquiry!</strong> We'll be in touch soon.
            </div>
            <div data-fs-error>
                <strong>Oops!</strong> Something went wrong. Please try again.
            </div>
            <form id={formElementId} class="form" data-form-id={formId}>
                <div class="form-row">
                    <div class="field">
                        <label for="name">Name</label>
                        <input id="name" name="name" type="text" autocomplete="name" placeholder="Jane Smith" required />
                        <span data-fs-error="name"></span>
                    </div>

                    <div class="field">
                        <label for="email">Email</label>
                        <input id="email" name="email" type="email" autocomplete="email" placeholder="jane@business.co.uk" required />
                        <span data-fs-error="email"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="field">
                        <label for="phone">Phone</label>
                        <input id="phone" name="phone" type="tel" autocomplete="tel" placeholder="07700 000000" />
                        <span data-fs-error="phone"></span>
                    </div>

                    <div class="field">
                        {
                            dropdownType === "package" ? (
                                <>
                                    <label for="business-type">Which package interests you?</label>
                                    <select id="business-type" name="business-type">
                                        <option value="">Select a package</option>
                                        <option>The Launch Pad – from £1,750</option>
                                        <option>The Core Business – from £2,750</option>
                                        <option>The Premium Growth – from £4,250</option>
                                        <option>Managed website – £249/mo</option>
                                        <option>Not sure yet</option>
                                    </select>
                                </>
                            ) : (
                                <>
                                    <label for="business-type">Business type</label>
                                    <select id="business-type" name="business-type">
                                        <option value="">Select one</option>
                                        <option>Startup</option>
                                        <option>Local business</option>
                                        <option>Service provider</option>
                                        <option>Trade business</option>
                                        <option>Consultant</option>
                                        <option>Other</option>
                                    </select>
                                </>
                            )
                        }
                        <span data-fs-error="business-type"></span>
                    </div>
                </div>

                <div class="field">
                    <label for="message">What do you need?</label>
                    <textarea id="message" name="message" placeholder="Tell us about your current website, business and what you want to improve."></textarea>
                        <span data-fs-error="message"></span>
                </div>

                <div class="field checkbox-field">
                    <label class="checkbox-label">
                        <input type="checkbox" name="privacy" required />
                        <span>I've read and agree to the <a href="/privacy" target="_blank">Privacy Policy</a></span>
                    </label>
                    <span data-fs-error="privacy"></span>
                </div>

                <button class="btn btn-primary" type="submit">Book my free consultation</button>
            </form>
        </div>
    </div>
</section>

<style>
    .cta {
        padding: 92px 0;
        background: var(--surface-soft);
    }

    .cta-panel {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 30px;
        padding: clamp(32px, 5vw, 58px);
        background:
            radial-gradient(circle at 0% 50%, rgba(15, 210, 187, 0.24), transparent 22rem),
            var(--secondary);
        border-radius: var(--radius-xl);
    }

    .form {
        display: grid;
        gap: 13px;
        padding: 18px;
        background: rgba(252, 252, 252, 0.74);
        border: 1px solid rgba(27, 25, 25, 0.10);
        border-radius: 26px;
        backdrop-filter: blur(12px);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 13px;
    }

    .field {
        display: grid;
        gap: 6px;
    }

    .field label {
        color: rgba(27, 25, 25, 0.58);
        font-size: 0.74rem;
        font-weight: 900;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .field input,
    .field select,
    .field textarea {
        width: 100%;
        min-height: 50px;
        padding: 12px 14px;
        color: var(--black);
        background: var(--white);
        border: 1px solid rgba(27, 25, 25, 0.12);
        border-radius: 14px;
        outline: none;
        transition:
            border-color 180ms ease,
            box-shadow 180ms ease;
    }

    .field textarea {
        min-height: 110px;
        resize: vertical;
    }

    .field input:focus,
    .field select:focus,
    .field textarea:focus {
        border-color: rgba(65, 0, 245, 0.46);
        box-shadow: 0 0 0 4px rgba(65, 0, 245, 0.10);
    }

    .form :global(.btn) {
        width: 100%;
        min-height: 54px;
    }

    .checkbox-field {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        font-size: 0.82rem;
        color: rgba(27, 25, 25, 0.52);
    }

    .checkbox-label a {
        color: var(--primary);
        text-decoration: underline;
    }

    .checkbox-label input[type="checkbox"] {
        width: 16px;
        height: 16px;
        min-height: unset;
        accent-color: var(--primary);
        cursor: pointer;
    }

    @media (max-width: 980px) {
        .cta-panel {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 640px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }

    [data-fs-error] {
        color: #dc3455;
        font-size: 0.82rem;
    }

    input[aria-invalid='true'],
    select[aria-invalid='true'],
    textarea[aria-invalid='true'] {
        border-color: #dc3455;
    }

    [data-fs-success][data-fs-active] {
        background: #d4edda;
        color: #155724;
        padding: 12px 16px;
        border-radius: 14px;
        margin-bottom: 16px;
        font-size: 0.92rem;
        display: flex;
        align-items: center;
        flex-direction: column;
        justify-content: center;
        text-align: center;
        line-height: 1;

        strong {
            font-size: 2rem;
            margin-bottom: 20px;
        }
    }

    [data-fs-error=''][data-fs-active] {
        background: #f8d7da;
        color: #721c24;
        padding: 12px 16px;
        border-radius: 14px;
        margin-bottom: 16px;
        font-size: 0.92rem;
    }
</style>

<script>
    import { initForm } from "@formspree/ajax";

    const ctaForm = document.querySelector('form[data-form-id]') as HTMLFormElement;
    const formId = ctaForm?.getAttribute('data-form-id') || 'mlgydvbn';
    const formElementId = ctaForm?.id || 'cta-form';

    initForm({
        formElement: `#${formElementId}`,
        formId: formId,
        onSuccess: () => {
            const form = document.querySelector(`#${formElementId}`) as HTMLFormElement;
            if (form) {
                form.style.display = 'none';
            }
        }
    });
</script>
