---
interface FAQItem {
    question: string;
    answer: string;
}

interface Props {
    eyebrow?: string;
    heading?: string;
    description?: string;
    questions?: FAQItem[];
}

const {
    eyebrow = "FAQ",
    heading = "Frequently asked questions.",
    description = "Got questions? We've got answers. If there's something we haven't covered, feel free to get in touch.",
    questions = [
        {
            question: "How long does a typical project take?",
            answer: "It depends on the scope. A single landing page typically takes 1-2 weeks, a 5-page site around 2-3 weeks, and a larger 10-page project with integrations can take 3-5 weeks. We'll give you a clear timeline before we start."
        },
        {
            question: "Do I need to provide content and images?",
            answer: "We can work with whatever you have. If you have copy and images ready, great. If not, we can help with copywriting and source high-quality stock imagery as part of the project."
        },
        {
            question: "Will my website be mobile-friendly?",
            answer: "Absolutely. Every site we build is fully responsive, so it'll look and perform great on phones, tablets, and desktops. We don't do separate mobile sites."
        },
        {
            question: "Can I update the site myself after launch?",
            answer: "We build your site so that making basic updates is straightforward. We can also provide ongoing support and maintenance if you'd prefer to leave it to us."
        },
        {
            question: "What if I'm not happy with the design?",
            answer: "We include rounds of revisions in every package to make sure you're happy with the result. We work closely with you throughout the process, so there are no surprises at the end."
        },
        {
            question: "Do you offer hosting and ongoing maintenance?",
            answer: "Yes. We can set up and manage hosting for you. We also offer maintenance and support retainers if you want ongoing updates, security patches, and peace of mind."
        },
        {
            question: "What's the process from start to launch?",
            answer: "We start with a discovery call to understand your goals. Then we design a custom mockup, build the site, review it with you, and finally deploy it live. The whole process is collaborative, with regular check-ins."
        }
    ]
} = Astro.props;
---

<section class="section section-soft" id="faq">
    <div class="container">
        <div class="faq-grid">
            <div class="faq-copy">
                <span class="eyebrow">{eyebrow}</span>
                <h2>{heading}</h2>
                <p class="lead">{description}</p>
            </div>

            <div class="faq-list">
                {questions.map((item) => (
                    <details>
                        <summary>{item.question}</summary>
                        <p>{item.answer}</p>
                    </details>
                ))}
            </div>
        </div>
    </div>
</section>

<style>
    .faq-grid {
        display: grid;
        grid-template-columns: 0.78fr 1.22fr;
        gap: 42px;
        align-items: start;
    }

    .faq-copy {
        position: sticky;
        top: 110px;
    }

    .faq-list {
        display: grid;
        gap: 12px;
    }

    details {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
    }

    summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 20px 22px;
        color: var(--black);
        font-weight: 800;
        cursor: pointer;
        list-style: none;
    }

    summary::-webkit-details-marker {
        display: none;
    }

    summary::after {
        content: "+";
        width: 28px;
        height: 28px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        color: var(--white);
        background: var(--primary);
        border-radius: 999px;
        font-weight: 800;
        transition: transform 180ms ease;
    }

    details[open] summary::after {
        transform: rotate(45deg);
    }

    details p {
        padding: 0 22px 22px;
        font-size: 0.94rem;
    }

    @media (max-width: 980px) {
        .faq-grid {
            grid-template-columns: 1fr;
        }

        .faq-copy {
            position: static;
        }
    }
</style>
