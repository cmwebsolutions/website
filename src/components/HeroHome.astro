---
import { topSites, bottomSites } from '../data/sites';
---

<section class="hero-home">
    <div class="hero-bg"></div>
    <div class="container">
        <div class="hero-grid">
            <div class="hero-content">
                <span class="eyebrow">CM Web Solutions</span>
                <h1>Design. Build. Grow.<br />Your website done right.</h1>
                <p class="lead">
                    We build high-performing websites for UK businesses, from single landing pages to full multi-page sites. No fluff, just purposeful design that drives results.
                </p>
                <div class="hero-ctas">
                    <a class="btn btn-accent" href="/work">View our work</a>
                    <a class="btn btn-ghost" href="/contact">Book a consultation</a>
                </div>
                <div class="hero-pills">
                    <span class="pill">Designed for your brand</span>
                    <span class="pill">SEO-optimised from day one</span>
                    <span class="pill">Fast &amp; mobile-friendly</span>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-marquee">
                    <div class="marquee-row">
                        <div class="marquee-track marquee-track--left">
                            {topSites.map(s => <img src={s.src} alt={s.alt} class="marquee-img" />)}
                            {topSites.map(s => <img src={s.src} alt={s.alt} class="marquee-img" />)}
                        </div>
                    </div>
                    <div class="marquee-row">
                        <div class="marquee-track marquee-track--right">
                            {bottomSites.map(s => <img src={s.src} alt={s.alt} class="marquee-img" />)}
                            {bottomSites.map(s => <img src={s.src} alt={s.alt} class="marquee-img" />)}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hero-home {
        position: relative;
        padding: 144px 0 112px;
        color: var(--white);
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 20%, rgba(65, 0, 245, 0.35) 0%, transparent 100%),
                    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(15, 210, 187, 0.15) 0%, transparent 100%),
                    var(--black);
        z-index: 0;
    }

    .hero-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(252, 252, 252, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(252, 252, 252, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
    }

    .hero-grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .hero-content {
        position: relative;
        z-index: 4;
    }

    .hero-content :global(.eyebrow) {
        color: var(--accent);
        background: rgba(15, 210, 187, 0.1);
        border-color: rgba(15, 210, 187, 0.2);
    }

    .hero-content :global(.eyebrow)::before {
        background: var(--accent);
        box-shadow: 0 0 0 5px rgba(15, 210, 187, 0.18);
    }

    .hero-content h1 {
        max-width: 100%;
        color: var(--white);
    }

    .hero-content :global(.lead) {
        max-width: 520px;
        color: var(--dark-muted);
    }

    .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-top: 36px;
    }

    .hero-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 42px;
    }

    .hero-pills :global(.pill) {
        font-size: 0.82rem;
    }

    .hero-visual {
        overflow: hidden;
        width: 60vw;
        margin-left: calc(50% - 40vw);
        transform: rotate(-5deg);
        opacity: 0.65;
    }

    .hero-marquee {
        display: grid;
        gap: 16px;
        padding: 12px 0;
    }

    .marquee-row {
        overflow: hidden;
        mask-image: linear-gradient(90deg, transparent 0%, black 5%, black 95%, transparent 100%);
        -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 5%, black 95%, transparent 100%);
    }

    .marquee-track {
        display: flex;
        gap: 20px;
        width: fit-content;
    }

    .marquee-track--left {
        animation: marquee-left 35s linear infinite;
    }

    .marquee-track--right {
        animation: marquee-right 35s linear infinite;
    }

    .marquee-img {
        width: 280px;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        border-radius: var(--radius-sm);
        border: 1px solid rgba(252, 252, 252, 0.12);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
        flex-shrink: 0;
        filter: grayscale(100%);
    }

    .marquee-img:nth-child(12n+1) { rotate: -3deg; }
    .marquee-img:nth-child(12n+2) { rotate: 2deg; }
    .marquee-img:nth-child(12n+3) { rotate: -1deg; }
    .marquee-img:nth-child(12n+4) { rotate: 3deg; }
    .marquee-img:nth-child(12n+5) { rotate: -2deg; }
    .marquee-img:nth-child(12n+6) { rotate: 1deg; }
    .marquee-img:nth-child(12n+7) { rotate: -3deg; }
    .marquee-img:nth-child(12n+8) { rotate: 2deg; }
    .marquee-img:nth-child(12n+9) { rotate: -1deg; }
    .marquee-img:nth-child(12n+10) { rotate: 3deg; }
    .marquee-img:nth-child(12n+11) { rotate: -2deg; }
    .marquee-img:nth-child(12n+12) { rotate: 1deg; }

    @keyframes marquee-left {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    @keyframes marquee-right {
        0% { transform: translateX(-50%); }
        100% { transform: translateX(0); }
    }

    @media (prefers-reduced-motion: reduce) {
        .marquee-track {
            animation: none;
            transform: none !important;
        }
        .marquee-row {
            mask: none;
            -webkit-mask: none;
        }
        .marquee-img {
            rotate: none !important;
        }
    }

    @media (max-width: 980px) {
        .hero-home {
            padding: 124px 0 80px;
        }

        .hero-grid {
            grid-template-columns: 1fr;
            gap: 48px;
        }

        .hero-visual {
            max-width: 480px;
        }

        .marquee-img {
            width: 200px;
        }

        .marquee-track {
            gap: 14px;
        }
    }

    @media (max-width: 640px) {
        .hero-home {
            padding: 110px 0 64px;
        }

        .hero-ctas :global(.btn) {
            width: 100%;
        }

        .hero-pills {
            flex-direction: column;
        }

        .marquee-img {
            width: 160px;
        }

        .marquee-track {
            gap: 10px;
        }

        .hero-visual {
            width: 100%;
            margin-left: 0;
        }
    }
</style>
