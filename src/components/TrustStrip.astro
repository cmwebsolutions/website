---
export interface TrustItem {
    title: string;
    description: string;
}

interface Props {
    items: TrustItem[];
}

const { items } = Astro.props;
---

<div class="trust-strip" aria-label="Trust highlights">
    <div class="container">
        <div class="trust-grid">
            {items.map((item) => (
                <div class="trust-card">
                    <strong>{item.title}</strong>
                    <span>{item.description}</span>
                </div>
            ))}
        </div>
    </div>
</div>

<style>
    .trust-strip {
        padding: 26px 0;
        background: var(--black);
        border-top: 1px solid rgba(252, 252, 252, 0.10);
        border-bottom: 1px solid rgba(252, 252, 252, 0.10);
    }

    .trust-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
    }

    .trust-card {
        padding: 19px;
        border-radius: 19px;
        background: rgba(252, 252, 252, 0.06);
        border: 1px solid rgba(252, 252, 252, 0.10);
    }

    .trust-card strong {
        display: block;
        color: var(--white);
        font-size: 0.96rem;
    }

    .trust-card span {
        display: block;
        margin-top: 4px;
        color: rgba(252, 252, 252, 0.56);
        font-size: 0.86rem;
    }

    @media (max-width: 980px) {
        .trust-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .trust-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
