---
import Globe from '@lucide/astro/icons/globe';
import Banknote from '@lucide/astro/icons/banknote';
import Clock from '@lucide/astro/icons/clock';
---

<section class="section" id="problem">
    <div class="container">
        <div class="problem-grid">
            <div class="problem-intro">
                <span class="eyebrow">The challenge</span>
                <h2>Your website shapes how customers see your business.</h2>
                <p>
                    A poor online presence costs you trust and sales before you even get a chance to win them over. Here's what we help you avoid.
                </p>
            </div>

            <div class="problem-cards">
                <article class="card problem-card">
                    <span class="problem-card-icon"><Globe size={24} /></span>
                    <h3>First impressions matter</h3>
                    <p>
                        Your website is often the first thing potential customers see. If it blends in or looks generic, you lose trust before you even get a chance to speak with them.
                    </p>
                </article>

                <article class="card problem-card">
                    <span class="problem-card-icon"><Banknote size={24} /></span>
                    <h3>Agencies don't fit the budget</h3>
                    <p>
                        Traditional agencies quote high because of overhead, not because the work is better. Fixed-price packages give you professional results without the premium.
                    </p>
                </article>

                <article class="card problem-card">
                    <span class="problem-card-icon"><Clock size={24} /></span>
                    <h3>Tech overhead drains your time</h3>
                    <p>
                        Hosting, updates, security, backups — the admin never stops. You should be focused on your customers, not maintaining a website.
                    </p>
                </article>
            </div>
        </div>
    </div>
</section>

<style>
    .problem-grid {
        display: grid;
        grid-template-columns: 0.86fr 1.14fr;
        gap: 18px;
    }

    .problem-intro {
        padding: clamp(32px, 5vw, 54px);
        color: var(--white);
        background:
            radial-gradient(circle at 100% 0%, rgba(15, 210, 187, 0.25), transparent 18rem),
            var(--black);
        border-radius: var(--radius-xl);
    }

    .problem-intro :global(.eyebrow) {
        color: var(--accent);
        background: rgba(15, 210, 187, 0.12);
        border-color: rgba(15, 210, 187, 0.24);
    }

    .problem-intro :global(h2) {
        color: var(--white);
        font-size: clamp(2.25rem, 4.8vw, 2.4rem);
    }

    .problem-intro p {
        margin-top: 18px;
        color: var(--dark-muted);
    }

    .problem-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .problem-cards :global(.card):first-child {
        grid-column: span 2;
    }

    .problem-card {
        display: flex;
        flex-direction: column;
    }

    .problem-card-icon {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        margin-bottom: 36px;
        color: var(--white);
        background: var(--primary);
        border-radius: 15px;
    }

    .problem-card-icon svg {
        display: block;
    }

    .problem-cards :global(.card):first-child .problem-card-icon {
        background: var(--accent);
        color: var(--black);
    }

    .problem-card p {
        flex: 1;
    }

    @media (max-width: 980px) {
        .problem-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 640px) {
        .problem-cards {
            grid-template-columns: 1fr;
        }

        .problem-cards :global(.card):first-child {
            grid-column: span 1;
        }
    }
</style>
