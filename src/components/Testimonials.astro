---
interface Testimonial {
    name: string;
    company: string;
    heading: string;
    quote: string;
}

interface Props {
    eyebrow?: string;
    heading?: string;
    description?: string;
    testimonials?: Testimonial[];
    layout?: "grid" | "featured";
}

const {
    eyebrow = "Testimonials",
    heading = "Trusted by businesses like yours.",
    description = "See what our clients have to say about working with us.",
    testimonials = [
        {
            name: "Will Grady",
            company: "Futurizm",
            heading: "Great landing page, great experience",
            quote: "As a tech start-up founder, finding good people is a challenge. I was referred to Custom Made Web Solutions and have been delighted \u2014 consultative, easy to work with, and landed me a great landing page at a competitive price. I highly recommend them."
        },
        {
            name: "Jakub Konecki",
            company: "Halny Tech Consulting",
            heading: "Always goes the extra mile",
            quote: "I can highly recommend Custom Made Web Solutions. Always helpful and goes the extra mile. They keep up with evolving technologies and often offer valuable suggestions for improvements."
        },
        {
            name: "Tim Field",
            company: "29homes",
            heading: "Reliable partner for years",
            quote: "I have used Custom Made Web Solutions for years for website design, hosting and maintenance. Always friendly, knowledgeable and gets the job done as required."
        }
    ],
    layout = "grid"
} = Astro.props;
---

<section class="section" id="testimonials">
    <div class="container">
        <div class="section-head">
            <div>
                <span class="eyebrow">{eyebrow}</span>
                <h2>{heading}</h2>
            </div>
            <p>{description}</p>
        </div>

        <div class="testimonial-grid" class:list={{ 'testimonial-grid--featured': layout === 'featured' }}>
            {testimonials.map((t, i) => (
                <article class="card testimonial-card" class:list={{ 'testimonial-card--featured': layout === 'featured' && (i === 0 || i === testimonials.length - 1) }}>
                    <div class="testimonial-content">
                        <span class="quote-mark" aria-hidden="true">&ldquo;</span>
                        <div class="quote-text">
                            <p class="quote-heading">{t.heading}</p>
                            <p>{t.quote}</p>
                        </div>
                    </div>
                    <div class="attribution">
                        <strong>{t.name}</strong>
                        <span>{t.company}</span>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .testimonial-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .testimonial-grid--featured {
        grid-template-columns: repeat(2, 1fr);
    }

    .testimonial-card--featured {
        grid-column: 1 / -1;
    }

    .testimonial-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 32px;
        transition:
            transform 180ms ease,
            box-shadow 180ms ease,
            border-color 180ms ease;
    }

    .testimonial-card--featured .quote-heading {
        font-size: 1.2rem;
    }

    .testimonial-card:hover {
        transform: translateY(-4px);
        border-color: rgba(65, 0, 245, 0.22);
        box-shadow: var(--shadow-soft);
    }

    .testimonial-content {
        display: flex;
        gap: 14px;
    }

    .quote-mark {
        flex: 0 0 auto;
        color: var(--primary);
        font-size: 3.2rem;
        font-weight: 800;
        line-height: 0.7;
    }

    .quote-text {
        display: grid;
        gap: 12px;
    }

    .quote-heading {
        color: var(--text);
        font-weight: 800;
        font-size: 1.08rem;
    }

    .quote-text p:last-child {
        color: var(--muted-strong);
        font-size: 0.94rem;
    }

    .attribution {
        display: grid;
        gap: 2px;
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

    .attribution strong {
        color: var(--text);
        font-size: 0.96rem;
        font-weight: 800;
    }

    .attribution span {
        color: var(--muted);
        font-size: 0.86rem;
    }

    @media (max-width: 980px) {
        .testimonial-grid,
        .testimonial-grid--featured {
            grid-template-columns: 1fr;
        }

        .testimonial-card--featured {
            grid-column: 1 / -1;
        }

        .testimonial-card {
            padding: 26px;
        }
    }
</style>
