---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
    title="Contact | CM Web Solutions | Get in Touch"
    description="Get in touch with CM Web Solutions. Fill in our contact form or email hello@cmwebsolutions.com. We'll respond within 24 hours."
    openGraph={{
        basic: {
            title: "Contact | CM Web Solutions | Get in Touch",
            type: "website",
            image: "/og-image.png",
        },
        optional: {
            siteName: "CM Web Solutions",
            locale: "en_GB",
        },
    }}
    twitter={{
        card: "summary_large_image",
        site: "@cmwebsolutions",
    }}
>
    <Header />
    <main>
        <section class="section contact-hero">
            <div class="contact-bg"></div>
            <div class="container">
                <div class="contact-hero-content">
                    <span class="eyebrow">Contact us</span>
                    <h1>Let's talk about your next website.</h1>
                    <p class="lead">Fill in the form below and we'll get back to you within 24 hours. No pressure, just a friendly chat about what you need.</p>
                </div>
            </div>
        </section>

        <section class="section section-soft">
            <div class="container">
                <div class="contact-grid">
                    <div class="contact-form-wrap">
                        <div data-fs-success>
                            <strong>Thanks for your message!</strong> We'll be in touch within 24 hours.
                        </div>
                        <div data-fs-error>
                            <strong>Oops!</strong> Something went wrong. Please try again or email us directly.
                        </div>
                        <form id="contact-form" class="contact-form" data-form-id="xdarkjga">
                            <div class="form-row">
                                <label class="form-label" for="name">Full name</label>
                                <input class="form-input" type="text" id="name" name="name" required placeholder="e.g. Jane Smith" />
                                <span data-fs-error="name"></span>
                            </div>
                            <div class="form-row">
                                <label class="form-label" for="email">Email address</label>
                                <input class="form-input" type="email" id="email" name="email" required placeholder="jane@example.com" />
                                <span data-fs-error="email"></span>
                            </div>
                            <div class="form-row">
                                <label class="form-label" for="phone">Phone number</label>
                                <input class="form-input" type="tel" id="phone" name="phone" placeholder="07700 900000" />
                                <span data-fs-error="phone"></span>
                            </div>
                            <div class="form-row">
                                <label class="form-label" for="budget">Which package interests you?</label>
                                <select class="form-input" id="budget" name="budget">
                                    <option value="">Select a package</option>
                                    <option value="launch-pad">The Launch Pad – £1,750</option>
                                    <option value="core-business">The Core Business – £2,750</option>
                                    <option value="premium-growth">The Premium Growth – £4,250</option>
                                    <option value="subscription">Managed website – £249/mo</option>
                                    <option value="not-sure">Not sure yet</option>
                                </select>
                                <span data-fs-error="budget"></span>
                            </div>
                            <div class="form-row">
                                <label class="form-label" for="message">Tell us about your project</label>
                                <textarea class="form-input form-textarea" id="message" name="message" rows="5" required placeholder="What kind of website do you need? What are your goals?"></textarea>
                                <span data-fs-error="message"></span>
                            </div>
                            <button class="btn btn-accent form-submit" type="submit">Send message</button>
                        </form>
                    </div>

                    <aside class="contact-info">
                        <div class="contact-info-card">
                            <h3>Email</h3>
                            <a href="mailto:hello@cmwebsolutions.com">hello@cmwebsolutions.com</a>
                        </div>
                        <div class="contact-info-card">
                            <h3>Phone</h3>
                            <span>0330 229 6586</span>
                        </div>
                        <div class="contact-info-card">
                            <h3>LinkedIn</h3>
                            <a href="https://www.linkedin.com/company/custom-made-web-solutions/" target="_blank">Connect with us</a>
                        </div>
                        <div class="contact-info-card">
                            <h3>Response time</h3>
                            <span>Mon–Fri, 9am–5pm</span>
                            <span class="contact-info-note">Usually within 1 business day</span>
                        </div>
                    </aside>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .contact-hero {
        position: relative;
        padding: 144px 0 100px;
        color: var(--white);
        overflow: hidden;
    }

    .contact-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 20%, rgba(65, 0, 245, 0.3) 0%, transparent 100%),
                    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(15, 210, 187, 0.12) 0%, transparent 100%),
                    var(--black);
        z-index: 0;
    }

    .contact-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(252, 252, 252, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(252, 252, 252, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
    }

    .contact-hero-content {
        position: relative;
        z-index: 1;
        max-width: 620px;
    }

    .contact-hero-content h1 {
        color: var(--white);
    }

    .contact-hero-content :global(.lead) {
        color: var(--dark-muted);
    }

    .contact-hero-content :global(.eyebrow) {
        color: var(--accent);
        background: rgba(15, 210, 187, 0.1);
        border-color: rgba(15, 210, 187, 0.2);
    }

    .contact-hero-content :global(.eyebrow)::before {
        background: var(--accent);
        box-shadow: 0 0 0 5px rgba(15, 210, 187, 0.18);
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1.3fr 0.7fr;
        gap: 48px;
        align-items: start;
    }

    .contact-form-wrap {
        background: var(--surface);
        padding: 36px 32px;
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
    }

    .form-row {
        margin-bottom: 22px;
    }

    .form-label {
        display: block;
        margin-bottom: 6px;
        font-weight: 700;
        font-size: 0.92rem;
    }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--surface-soft);
        font-size: 0.96rem;
        color: var(--text);
        outline: none;
        transition: border-color 180ms ease, box-shadow 180ms ease;
    }

    .form-input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(65, 0, 245, 0.1);
    }

    .form-textarea {
        resize: vertical;
        min-height: 120px;
    }

    .form-submit {
        width: 100%;
        margin-top: 8px;
    }

    .contact-info {
        display: grid;
        gap: 16px;
    }

    .contact-info-card {
        padding: 22px 24px;
        background: var(--surface);
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
    }

    .contact-info-card h3 {
        font-size: 0.88rem;
        color: var(--muted);
        margin-bottom: 4px;
    }

    .contact-info-card a {
        font-weight: 700;
        font-size: 1.02rem;
        transition: color 180ms ease;
    }

    .contact-info-card a:hover {
        color: var(--primary);
    }

    .contact-info-card span {
        font-weight: 700;
        font-size: 1.02rem;
    }

    .contact-info-note {
        display: block;
        margin-top: 4px;
        font-weight: 500;
        font-size: 0.86rem;
        color: var(--muted);
    }

    @media (max-width: 980px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }

        .contact-info {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .contact-info {
            grid-template-columns: 1fr;
        }
    }

    [data-fs-error] {
        color: #dc3455;
        font-size: 0.82rem;
    }

    input[aria-invalid='true'],
    select[aria-invalid='true'],
    textarea[aria-invalid='true'] {
        border-color: #dc3455;
    }

    [data-fs-success][data-fs-active] {
        background: #d4edda;
        color: #155724;
        padding: 24px 20px;
        border-radius: var(--radius-md);
        font-size: 0.92rem;
        display: flex;
        align-items: center;
        flex-direction: column;
        justify-content: center;
        text-align: center;
        line-height: 1;

        strong {
            font-size: 1.4rem;
            margin-bottom: 12px;
        }
    }

    [data-fs-error=""][data-fs-active] {
        background: #f8d7da;
        color: #721c24;
        padding: 12px 16px;
        border-radius: var(--radius-sm);
        font-size: 0.92rem;
        margin-bottom: 16px;
    }
</style>

<script>
    import { initForm } from "@formspree/ajax";

    initForm({
        formElement: '#contact-form',
        formId: 'xdarkjga',
        onSuccess: () => {
            const form = document.querySelector('#contact-form') as HTMLFormElement;
            if (form) {
                form.style.display = 'none';
            }
        }
    });
</script>
