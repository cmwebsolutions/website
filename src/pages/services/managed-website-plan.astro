---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import Problem from '../../components/Problem.astro';
import Features from '../../components/Features.astro';
import Process from '../../components/Process.astro';
import Pricing from '../../components/Pricing.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { testimonials } from '../../data/testimonials';
---

<Layout
    title="Managed Website Plan | CM Web Solutions"
    description="Managed website plan for UK businesses. £499 one-off setup, then £249/month. Includes design, hosting, SSL certificates, backups, maintenance and support."
    openGraph={{
        basic: {
            title: "Managed Website Plan | CM Web Solutions",
            type: "website",
            image: "/og-image.png",
        },
        optional: {
            siteName: "CM Web Solutions",
            locale: "en_GB",
        },
    }}
    twitter={{
        card: "summary_large_image",
        site: "@cmwebsolutions",
    }}
>
    <Header />
    <main>
        <Hero />
        <TrustStrip
            items={[
                {
                    title: "Designed properly",
                    description: "Human-made approach to building your website."
                },
                {
                    title: "Built for mobile",
                    description: "Responsive across modern devices, ensuring a smooth experience."
                },
                {
                    title: "Managed for you",
                    description: "Hosting, updates and support included."
                },
                {
                    title: "Predictable cost",
                    description: "One simple monthly subscription, no surprises."
                }
            ]}
        />
        <Problem />
        <Features />
        <Process
            steps={[
                {
                    heading: "Discover",
                    description: "We learn about your business, your offer, your audience and what the website needs to achieve."
                },
                {
                    heading: "Shape",
                    description: "We turn your business into a clear website structure with focused pages and messaging."
                },
                {
                    heading: "Launch",
                    description: "We design, build, test and launch your website so it is ready to start generating trust."
                },
                {
                    heading: "Support",
                    description: "After launch, we continue to manage hosting, maintenance, updates and support as part of your managed plan."
                }
            ]}
        />
        <Pricing />
        <Testimonials
            testimonials={[
                testimonials[9],
                testimonials[10],
                testimonials[3],
            ]}
        />
        <FAQ
    eyebrow="FAQ"
    heading="Clear answers before you commit."
    description="If you are unsure whether the managed plan is right for your business, book a free consultation and we'll talk through it."
    questions={[
        {
            question: "Is there a minimum term?",
            answer: "Yes. The managed website plan has a 12-month minimum agreement. This ensures we can invest the time to design, build and launch your site properly while spreading the cost."
        },
        {
            question: "What is the setup fee for?",
            answer: "The £499 one-off setup fee covers the design, development and launch of your website. After that, the monthly fee covers hosting, maintenance, support and ongoing updates."
        },
        {
            question: "Can I add extra pages?",
            answer: "Yes. Additional pages beyond the 5 included can be built and added. The cost depends on the complexity and we'll provide a quote before any work begins."
        },
        {
            question: "Who owns the website?",
            answer: "You own your content, copy and brand assets from day one. The website itself is provided as part of the managed service during the 12-month term. After successfully completing the 12-month minimum agreement, full ownership of the website transfers to you at no additional cost."
        },
        {
            question: "What happens if I cancel early?",
            answer: "If you cancel before the 12-month minimum term has ended, the remaining balance of the minimum term becomes payable. This protects the investment made in designing and building your site."
        },
        {
            question: "What happens after 12 months?",
            answer: "After the minimum term you have three options: continue on the £249/month managed care plan with full support and updates; downgrade to a £50/month hosting-only plan; or move the website to another provider once ownership has transferred."
        },
        {
            question: "Is ongoing SEO included?",
            answer: "Basic on-page SEO setup is included as part of the initial build. Ongoing SEO campaigns, content creation, technical SEO and link building are separate services."
        }
    ]}
/>
        <CTA
    dropdownType="package"
    eyebrow="Free consultation"
    heading="Let's see if the managed plan fits your business."
    description="Send a few details and we'll tell you whether this plan makes sense, what it would include, and what the next step looks like."
    formId="xzzpzegw"
/>
    </main>
    <Footer />
</Layout>
