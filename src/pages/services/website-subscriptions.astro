---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import Problem from '../../components/Problem.astro';
import Features from '../../components/Features.astro';
import Process from '../../components/Process.astro';
import Pricing from '../../components/Pricing.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Professional Websites from £149/month | CM Web Solutions">
    <Header />
    <main>
        <Hero />
        <TrustStrip />
        <Problem />
        <Features />
        <Process />
        <Pricing />
        <Testimonials />
        <FAQ
    eyebrow="FAQ"
    heading="Clear answers before you commit."
    description="If you are unsure whether the subscription model is right for your business, book a free consultation and we'll talk through it."
    questions={[
        {
            question: "Is there a minimum term?",
            answer: "Yes. The website subscription has a 12-month minimum term. This allows the design, build, launch and support to be spread across the subscription."
        },
        {
            question: "Can I upgrade later?",
            answer: "Yes. If you need extra pages beyond the 5 included, ecommerce, booking systems, landing pages or ongoing marketing support, we can move you onto a more suitable plan."
        },
        {
            question: "Can I add extra pages?",
            answer: "Yes. Additional pages beyond the 5 included can be built and added for a one-off fee of £100 per page. Your monthly subscription stays at £149 the extra page is a single payment, not a price increase."
        },
        {
            question: "Who owns the website?",
            answer: "You own your content, copy and brand assets. The website build and platform remain part of the managed subscription service. After the 12-month minimum term, you can purchase the full website outright for a one-off fee, discussed and confirmed before you sign up."
        },
        {
            question: "What counts as support?",
            answer: "Support includes basic maintenance, updates and reasonable minor changes. Larger new features or new pages may be quoted separately."
        },
        {
            question: "Can I cancel after 12 months?",
            answer: "Yes. After the 12-month minimum term, you can cancel with one month's notice. At that point hosting and support will stop and the site will be taken offline. If you want to keep the site live elsewhere, you can purchase it outright for a one-off fee confirmed before you sign up."
        },
        {
            question: "Is ongoing SEO included?",
            answer: "Basic SEO setup is included. Ongoing SEO campaigns, content creation, technical SEO and link building are separate services."
        }
    ]}
/>
        <CTA
    eyebrow="Free consultation"
    heading="Let's see if the subscription model fits your business."
    description="Send a few details and we'll tell you whether this plan makes sense, what it would include, and what the next step looks like."
    formId="xzzpzegw"
/>
    </main>
    <Footer />
</Layout>