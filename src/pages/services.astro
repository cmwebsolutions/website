---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Testimonials from '../components/Testimonials.astro';
import { testimonials } from '../data/testimonials';
import Rocket from '@lucide/astro/icons/rocket';
import Star from '@lucide/astro/icons/star';
import Gem from '@lucide/astro/icons/gem';
import Target from '@lucide/astro/icons/target';
import MonitorSmartphone from '@lucide/astro/icons/monitor-smartphone';
import Headphones from '@lucide/astro/icons/headphones';
---

<Layout
    title="Services | CM Web Solutions | Packages"
    description="Web design services for every stage of your business. Choose from The Launch Pad (£1,750), The Core Business (£2,750), or The Premium Growth (£4,250)."
    openGraph={{
        basic: {
            title: "Services | CM Web Solutions | Packages",
            type: "website",
            image: "/og-image.png",
        },
        optional: {
            siteName: "CM Web Solutions",
            locale: "en_GB",
        },
    }}
    twitter={{
        card: "summary_large_image",
        site: "@cmwebsolutions",
    }}
>
    <Header />
    <main>
        <section class="section services-hero">
            <div class="services-bg"></div>
            <div class="container">
                <div class="services-hero-content">
                    <span class="eyebrow">What we offer</span>
                    <h1>Web design services for every stage of your business.</h1>
                    <p class="lead">Whether you need a single landing page or a full-featured website with custom integrations, we have a package that fits.</p>
                </div>
            </div>
        </section>

        <section class="section section-soft">
            <div class="container">
                <div class="services-grid">
                    <article class="service-card">
                        <div class="service-icon"><Rocket size={24} /></div>
                        <h2 class="service-title">The Launch Pad</h2>
                        <p class="service-price">£1,750 <span>one-off</span></p>
                        <p class="service-desc">A single high-converting landing page designed to turn visitors into leads. Ideal for Google Ads, Meta campaigns, or product launches.</p>
                        <ul class="check-list">
                            <li><span class="check">✓</span> Single long-form landing page</li>
                            <li><span class="check">✓</span> High-converting copy & design</li>
                            <li><span class="check">✓</span> Mobile & tablet responsive</li>
                            <li><span class="check">✓</span> SEO meta tags & schema</li>
                            <li><span class="check">✓</span> Speed optimised</li>
                            <li><span class="check">✓</span> 1 round of revisions</li>
                        </ul>
                        <a href="/contact" class="btn btn-primary">Get started</a>
                    </article>

                    <article class="service-card service-card--featured">
                        <span class="service-badge">Most popular</span>
                        <div class="service-icon"><Star size={24} /></div>
                        <h2 class="service-title">The Core Business</h2>
                        <p class="service-price">£2,750 <span>one-off</span></p>
                        <p class="service-desc">A complete business website with up to 5 pages. Perfect for service providers, local businesses, and startups ready to establish their online presence.</p>
                        <ul class="check-list">
                            <li><span class="check">✓</span> Up to 5 custom pages</li>
                            <li><span class="check">✓</span> Home, About, Services, Reviews, Contact</li>
                            <li><span class="check">✓</span> Mobile & tablet responsive</li>
                            <li><span class="check">✓</span> On-page SEO for all pages</li>
                            <li><span class="check">✓</span> Contact form integration</li>
                            <li><span class="check">✓</span> 2 rounds of revisions</li>
                        </ul>
                        <a href="/contact" class="btn btn-accent">Get started</a>
                    </article>

                    <article class="service-card">
                        <div class="service-icon"><Gem size={24} /></div>
                        <h2 class="service-title">The Premium Growth</h2>
                        <p class="service-price">£4,250 <span>one-off</span></p>
                        <p class="service-desc">A full-featured website with up to 10 pages and advanced integrations: booking engines, CRM syncing, or custom forms for growing businesses.</p>
                        <ul class="check-list">
                            <li><span class="check">✓</span> Up to 10 custom pages</li>
                            <li><span class="check">✓</span> Advanced integrations</li>
                            <li><span class="check">✓</span> Booking engine or CRM sync</li>
                            <li><span class="check">✓</span> Custom forms & workflows</li>
                            <li><span class="check">✓</span> Priority support</li>
                            <li><span class="check">✓</span> 3 rounds of revisions</li>
                        </ul>
                        <a href="/contact" class="btn btn-primary">Get started</a>
                    </article>
                </div>
            </div>
        </section>

        <section class="section section-soft">
            <div class="container">
                <div class="section-head">
                    <div>
                        <span class="eyebrow">What to expect</span>
                        <h2>Websites you can trust, backed by support.</h2>
                    </div>
                    <p>Every project follows the same commitment to quality, no matter which package you choose.</p>
                </div>

                <div class="expect-grid">
                    <article class="expect-card">
                        <div class="expect-icon"><Target size={24} /></div>
                        <h3>Built around your goals</h3>
                        <p>Designed around your specific audience and what you need them to do. No generic layouts, no one-size-fits-all approach.</p>
                    </article>

                    <article class="expect-card">
                        <div class="expect-icon"><MonitorSmartphone size={24} /></div>
                        <h3>Tested on every device</h3>
                        <p>Every site is built and checked across mobile, tablet, and desktop screen sizes so you never lose a visitor to a broken layout.</p>
                    </article>

                    <article class="expect-card">
                        <div class="expect-icon"><Headphones size={24} /></div>
                        <h3>Ongoing support available</h3>
                        <p>Optional hosting, updates, and maintenance plans keep your site running smoothly once it's live. You're not on your own after launch.</p>
                    </article>
                </div>
            </div>
        </section>

        <section class="section">
            <div class="container">
                <div class="alt-offer">
                    <div class="alt-offer-content">
                        <span class="eyebrow">Alternative</span>
                        <h2>Prefer to pay monthly?</h2>
                        <p class="alt-offer-desc">We also offer our managed website plan at £249/month with a £499 setup fee. Includes hosting, SSL, backups, maintenance and support.</p>
                        <a href="/services/website-subscriptions" class="btn btn-dark">View managed plan</a>
                    </div>
                    <div class="alt-offer-visual">
                        <div class="alt-offer-card">
                            <span class="alt-offer-card-price">£249<span>/mo</span></span>
                            <span class="alt-offer-card-label">£499 setup</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <Testimonials
            heading="Trusted by businesses we've built for."
            description="See what our clients say about working with us on their websites."
            testimonials={[
                testimonials[5],
                testimonials[3],
                testimonials[4],
                testimonials[8],
            ]}
        />

        <FAQ />
        <CTA />
    </main>
    <Footer />
</Layout>

<style>
    .services-hero {
        position: relative;
        padding: 144px 0 100px;
        color: var(--white);
        overflow: hidden;
    }

    .services-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 20%, rgba(65, 0, 245, 0.3) 0%, transparent 100%),
                    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(15, 210, 187, 0.12) 0%, transparent 100%),
                    var(--black);
        z-index: 0;
    }

    .services-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(252, 252, 252, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(252, 252, 252, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
    }

    .services-hero-content {
        position: relative;
        z-index: 1;
        max-width: 700px;
        margin-inline: auto;
        text-align: center;
    }

    .services-hero-content h1 {
        color: var(--white);
        margin-inline: auto;
    }

    .services-hero-content :global(.lead) {
        color: var(--dark-muted);
        margin-inline: auto;
    }

    .services-hero-content :global(.eyebrow) {
        color: var(--accent);
        background: rgba(15, 210, 187, 0.1);
        border-color: rgba(15, 210, 187, 0.2);
        margin-inline: auto;
    }

    .services-hero-content :global(.eyebrow)::before {
        background: var(--accent);
        box-shadow: 0 0 0 5px rgba(15, 210, 187, 0.18);
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
        align-items: start;
    }

    .service-card {
        display: flex;
        flex-direction: column;
        padding: 36px 32px 32px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        transition: transform 240ms ease, box-shadow 240ms ease;
    }

    .service-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-card);
    }

    .service-card--featured {
        position: relative;
        border-color: var(--accent);
    }

    .service-badge {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        padding: 6px 16px;
        background: var(--accent);
        color: var(--black);
        font-size: 0.78rem;
        font-weight: 800;
        border-radius: 999px;
        white-space: nowrap;
    }

    .service-icon {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        border-radius: 15px;
        color: var(--white);
        background: var(--primary);
        margin-bottom: 20px;
    }

    .service-icon svg {
        display: block;
    }

    .service-card--featured .service-icon {
        background: var(--accent);
        color: var(--black);
    }

    .service-title {
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1.08;
        margin-bottom: 8px;
    }

    .service-price {
        font-size: 2.2rem;
        font-weight: 900;
        line-height: 1;
        margin-bottom: 16px;
        padding-bottom: 18px;
        border-bottom: 1px solid var(--border);
    }

    .service-price span {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--muted);
        margin-left: 6px;
    }

    .service-desc {
        font-size: 0.92rem;
        color: var(--muted);
        margin-bottom: 20px;
        flex: 1;
    }

    .service-card :global(.check-list) {
        margin-top: 0;
        margin-bottom: 28px;
    }

    .service-card :global(.check-list li) {
        font-size: 0.92rem;
    }

    .alt-offer {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 60px;
        align-items: center;
        background: var(--surface-soft);
        border-radius: var(--radius-lg);
        padding: 56px 48px;
    }

    .alt-offer-desc {
        margin-top: 16px;
        font-size: 1.02rem;
    }

    .alt-offer-content :global(.btn) {
        margin-top: 28px;
    }

    .alt-offer-visual {
        display: flex;
        justify-content: center;
    }

    .alt-offer-card {
        text-align: center;
        padding: 36px 48px;
        background: var(--black);
        border-radius: var(--radius-md);
        color: var(--white);
    }

    .alt-offer-card-price {
        font-size: 3rem;
        font-weight: 900;
        line-height: 1;
    }

    .alt-offer-card-price span {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--dark-muted);
    }

    .alt-offer-card-label {
        display: block;
        margin-top: 6px;
        font-size: 0.92rem;
        color: var(--accent);
        font-weight: 700;
    }

    .expect-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
    }

    .expect-card {
        min-height: 220px;
        display: flex;
        flex-direction: column;
        padding: 26px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    }

    .expect-card:hover {
        transform: translateY(-4px);
        border-color: rgba(65, 0, 245, 0.22);
        box-shadow: var(--shadow-soft);
    }

    .expect-icon {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        margin-bottom: 36px;
        color: var(--white);
        background: var(--primary);
        border-radius: 15px;
    }

    .expect-icon svg {
        display: block;
    }

    .expect-card:nth-child(2) .expect-icon {
        color: var(--black);
        background: var(--accent);
    }

    .expect-card:nth-child(3) .expect-icon {
        color: var(--accent);
        background: var(--black);
    }

    .expect-card h3 {
        font-size: 1.12rem;
        font-weight: 800;
        line-height: 1.15;
    }

    .expect-card p {
        margin-top: 12px;
        font-size: 0.92rem;
        flex: 1;
    }

    @media (max-width: 980px) {
        .services-grid {
            grid-template-columns: 1fr;
            max-width: 480px;
            margin-inline: auto;
        }

        .expect-grid {
            grid-template-columns: 1fr;
            max-width: 480px;
            margin-inline: auto;
        }

        .alt-offer {
            grid-template-columns: 1fr;
            text-align: center;
            padding: 40px 28px;
        }
    }
</style>
