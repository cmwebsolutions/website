---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroHome from '../components/HeroHome.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Packages from '../components/Packages.astro';
import Process from '../components/Process.astro';
import Portfolio from '../components/Portfolio.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { testimonials } from '../data/testimonials';
import { projects } from '../data/projects';
---

<Layout title="CM Web Solutions | Professional Web Design & Development">
    <Header />
    <main>
        <HeroHome />
        <TrustStrip
            items={[
                {
                    title: "Designed properly",
                    description: "Human-made approach to building your website."
                },
                {
                    title: "Built for mobile",
                    description: "Responsive across modern devices, ensuring a smooth experience."
                },
                {
                    title: "Yours to keep",
                    description: "Full ownership of your website with no recurring fees."
                },
                {
                    title: "Fixed price",
                    description: "A single investment with no hidden costs or surprises."
                }
            ]}
        />
        <Packages />
        <Process />
        <Portfolio projects={projects.slice(0, 6)} />
        <Testimonials
            layout="featured"
            testimonials={[
                testimonials[2],
                testimonials[0],
                testimonials[1],
            ]}
        />
        <FAQ />
        <CTA />
    </main>
    <Footer />
</Layout>
