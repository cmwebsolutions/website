---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CM Web Solutions | Professional Web Design & Development">

    <main class="index-placeholder">
        <div class="container">
            <h1>We're building something new.</h1>
            <p class="lead">Our website is being rebuilt. In the meantime, you can see our current service offering.</p>
            <a class="btn btn-primary" href="/services/website-subscriptions">View website subscriptions</a>
        </div>
    </main>
</Layout>

<style>
    .index-placeholder {
        padding: 92px 0;
        background: var(--surface-soft);
        min-height: 100vh;
    }

    .index-placeholder .container {
        max-width: 640px;
        text-align: center;
    }

    .index-placeholder h1 {
        margin-bottom: 16px;
    }

    .index-placeholder .lead {
        margin-top: 0;
        margin-bottom: 32px;
    }
</style>