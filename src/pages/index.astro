---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroHome from '../components/HeroHome.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Packages from '../components/Packages.astro';
import Process from '../components/Process.astro';
import Portfolio from '../components/Portfolio.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { testimonials } from '../data/testimonials';
import { projects } from '../data/projects';
---

<Layout
    title="CM Web Solutions | Professional Web Design & Development"
    description="Professional web design and development for UK businesses. Custom websites from landing pages to full multi-page sites, designed to help you grow online."
    openGraph={{
        basic: {
            title: "CM Web Solutions | Professional Web Design & Development",
            type: "website",
            image: "/og-image.png",
        },
        optional: {
            siteName: "CM Web Solutions",
            locale: "en_GB",
            description: "Professional web design and development for UK businesses. Custom websites from landing pages to full multi-page sites, designed to help you grow online.",
        },
    }}
    twitter={{
        card: "summary_large_image",
        site: "@cmwebsolutions",
        description: "Professional web design and development for UK businesses. Custom websites from landing pages to full multi-page sites, designed to help you grow online.",
    }}
>
    <Header />
    <main>
        <HeroHome />
        <TrustStrip
            items={[
                {
                    title: "Designed properly",
                    description: "Human-made approach to building your website."
                },
                {
                    title: "Built for mobile",
                    description: "Responsive across modern devices, ensuring a smooth experience."
                },
                {
                    title: "Fast & SEO-ready",
                    description: "Quick load times and strong on-page SEO foundations."
                },
                {
                    title: "Support options",
                    description: "Ongoing updates and hosting available if you want us to look after it."
                }
            ]}
        />
        <Packages />
        <Process />
        <Portfolio projects={projects.slice(0, 6)} />
        <Testimonials
            layout="featured"
            testimonials={[
                testimonials[2],
                testimonials[0],
                testimonials[1],
                testimonials[11],
            ]}
        />
        <FAQ />
        <CTA />
    </main>
    <Footer />
</Layout>
