---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroHome from '../components/HeroHome.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ProblemHome from '../components/ProblemHome.astro';
import Process from '../components/Process.astro';
import Portfolio from '../components/Portfolio.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { testimonials } from '../data/testimonials';
import { projects } from '../data/projects';
---

<Layout
    title="CM Web Solutions | Professional Web Design & Development"
    description="Professional web design and development for UK businesses. Custom websites from landing pages to full multi-page sites, designed to help you grow online."
    openGraph={{
        basic: {
            title: "CM Web Solutions | Professional Web Design & Development",
            type: "website",
            image: "/og-image.png",
        },
        optional: {
            siteName: "CM Web Solutions",
            locale: "en_GB",
            description: "Professional web design and development for UK businesses. Custom websites from landing pages to full multi-page sites, designed to help you grow online.",
        },
    }}
    twitter={{
        card: "summary_large_image",
        site: "@cmwebsolutions",
        description: "Professional web design and development for UK businesses. Custom websites from landing pages to full multi-page sites, designed to help you grow online.",
    }}
>
    <Header />
    <main>
        <HeroHome />
        <TrustStrip
            items={[
                {
                    title: "Designed properly",
                    description: "Human-made approach to building your website."
                },
                {
                    title: "Built for mobile",
                    description: "Responsive across modern devices, ensuring a smooth experience."
                },
                {
                    title: "Fast & SEO-ready",
                    description: "Quick load times and strong on-page SEO foundations."
                },
                {
                    title: "Support options",
                    description: "Ongoing updates and hosting available if you want us to look after it."
                }
            ]}
        />
        <ProblemHome />
        <Process />
        <Portfolio projects={projects.slice(0, 6)} />
        <section class="section section-soft">
            <div class="container">
                <div class="cta-banner">
                    <h2>Ready to get started?</h2>
                    <p>Your website built by a developer who knows code. We use the right approach for each project based on what you actually need.</p>
                    <a href="/services" class="btn btn-accent cta-banner-btn">View Packages</a>
                </div>
            </div>
        </section>

        <Testimonials
            layout="featured"
            testimonials={[
                testimonials[2],
                testimonials[0],
                testimonials[1],
                testimonials[11],
            ]}
        />
        <FAQ />
        <CTA />
    </main>
    <Footer />
</Layout>

<style>
    .cta-banner {
        text-align: center;
        max-width: 600px;
        margin-inline: auto;
    }

    .cta-banner h2 {
        margin-inline: auto;
    }

    .cta-banner p {
        margin-top: 16px;
        font-size: 1.04rem;
    }

    .cta-banner-btn {
        margin-top: 32px;
    }
</style>
