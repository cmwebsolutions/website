---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Testimonials from '../components/Testimonials.astro';
import { testimonials } from '../data/testimonials';
---

<Layout title="Our Work | CM Web Solutions | Portfolio">
    <Header />
    <main>
        <section class="section work-hero">
            <div class="work-bg"></div>
            <div class="container">
                <div class="work-hero-content">
                    <span class="eyebrow">Our work</span>
                    <h1>Real websites for real businesses.</h1>
                    <p class="lead">Every project is different, but our approach stays the same: understand the goal, design with purpose, and deliver something that works.</p>
                </div>
            </div>
        </section>

        <section class="section section-soft">
            <div class="container">
                <div class="work-grid">
                    <article class="work-card">
                        <div class="work-thumb work-thumb--1">
                            <span class="work-label">Recruitment</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Aila Recruitment</h2>
                            <p class="work-desc">A WordPress recruitment website with job listings, company information, and candidate contact forms.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Recruitment</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--2">
                            <span class="work-label">Corporate</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">EOR International</h2>
                            <p class="work-desc">A corporate WordPress site for an international employment services company with multi-language support.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Corporate</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--3">
                            <span class="work-label">Fitness</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Impact Personal Training</h2>
                            <p class="work-desc">A fitness brand website with trainer profiles, class schedules, and booking integration.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Fitness</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--4">
                            <span class="work-label">Trade</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">JDC Scaffolding</h2>
                            <p class="work-desc">A trade services website with service area information, project gallery, and quote request functionality.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Trade</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--5">
                            <span class="work-label">Recruitment</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Luton Jobs and Skills</h2>
                            <p class="work-desc">A jobs and skills website connecting local employers with candidates, featuring job listings and training resources.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Recruitment</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--6">
                            <span class="work-label">Finance</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">SAS Accountants</h2>
                            <p class="work-desc">A WordPress accounting firm website with detailed service pages and client portal integration.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Finance</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--1">
                            <span class="work-label">Finance</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">SAS Micro</h2>
                            <p class="work-desc">A micro business accounting website tailored for smaller enterprises with simplified service offerings.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Finance</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--2">
                            <span class="work-label">Finance</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">SAS Funding</h2>
                            <p class="work-desc">A funding advisory website with application forms, eligibility information, and success stories.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Finance</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--3">
                            <span class="work-label">Finance</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">SAS Tax</h2>
                            <p class="work-desc">A tax advisory website with service breakdowns, tax guides, and compliance resources.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Finance</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--4">
                            <span class="work-label">Finance</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Select Tax And Accounts</h2>
                            <p class="work-desc">A tax and accounting firm website with expert profiles, service pages, and appointment booking.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Finance</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--5">
                            <span class="work-label">Finance</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">UK Credit Insurance</h2>
                            <p class="work-desc">A credit insurance website with policy information, quote generation, and industry resources.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Finance</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--6">
                            <span class="work-label">Marketing</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Group Promotions</h2>
                            <p class="work-desc">A promotional products website with product catalogue, custom ordering, and client account management.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Marketing</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--1">
                            <span class="work-label">Startup</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Futurizm</h2>
                            <p class="work-desc">A tech startup website showcasing innovative products, company vision, and investor information.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Startup</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--2">
                            <span class="work-label">Recruitment</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Clarion Search</h2>
                            <p class="work-desc">A headhunting and executive search website with industry specialisms and consultant profiles.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Recruitment</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--3">
                            <span class="work-label">Professional Services</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Haley Bridge</h2>
                            <p class="work-desc">A professional services website with detailed case studies, team profiles, and service portfolio.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Professional Services</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--4">
                            <span class="work-label">Trade</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Monster Clearance</h2>
                            <p class="work-desc">A clearance and waste management website with service areas, pricing information, and instant quote requests.</p>
                            <div class="work-tags">
                                <span class="work-tag">WordPress</span>
                                <span class="work-tag">Trade</span>
                            </div>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <Testimonials
            heading="Websites our clients are proud of."
            description="See what our clients say about the websites we've built for them."
            testimonials={[
                testimonials[0],
                testimonials[1],
            ]}
        />

        <CTA />
    </main>
    <Footer />
</Layout>

<style>
    .work-hero {
        position: relative;
        padding: 144px 0 100px;
        color: var(--white);
        overflow: hidden;
    }

    .work-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 20%, rgba(65, 0, 245, 0.3) 0%, transparent 100%),
                    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(15, 210, 187, 0.12) 0%, transparent 100%),
                    var(--black);
        z-index: 0;
    }

    .work-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(252, 252, 252, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(252, 252, 252, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
    }

    .work-hero-content {
        position: relative;
        z-index: 1;
        max-width: 640px;
    }

    .work-hero-content h1 {
        color: var(--white);
    }

    .work-hero-content :global(.lead) {
        color: var(--dark-muted);
    }

    .work-hero-content :global(.eyebrow) {
        color: var(--accent);
        background: rgba(15, 210, 187, 0.1);
        border-color: rgba(15, 210, 187, 0.2);
    }

    .work-hero-content :global(.eyebrow)::before {
        background: var(--accent);
        box-shadow: 0 0 0 5px rgba(15, 210, 187, 0.18);
    }

    .work-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
    }

    .work-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        overflow: hidden;
        transition: transform 240ms ease, box-shadow 240ms ease;
    }

    .work-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-card);
    }

    .work-thumb {
        position: relative;
        height: 220px;
        display: flex;
        align-items: flex-start;
        justify-content: flex-end;
        padding: 18px;
    }

    .work-thumb--1 { background: linear-gradient(135deg, #4100F5, #7B4AFF); }
    .work-thumb--2 { background: linear-gradient(135deg, #0FD2BB, #0AA8D2); }
    .work-thumb--3 { background: linear-gradient(135deg, #FF6B6B, #EE5A24); }
    .work-thumb--4 { background: linear-gradient(135deg, #6C5CE7, #A29BFE); }
    .work-thumb--5 { background: linear-gradient(135deg, #1B1919, #444); }
    .work-thumb--6 { background: linear-gradient(135deg, #00B894, #00CEC9); }

    .work-label {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
        color: var(--white);
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .work-info {
        padding: 22px 24px 24px;
    }

    .work-title {
        font-size: 1.15rem;
        font-weight: 800;
        line-height: 1.08;
        margin-bottom: 8px;
    }

    .work-desc {
        font-size: 0.9rem;
        color: var(--muted);
    }

    .work-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 14px;
    }

    .work-tag {
        font-size: 0.76rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
        color: var(--primary);
        background: rgba(65, 0, 245, 0.08);
    }

    @media (max-width: 980px) {
        .work-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .work-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
