---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Our Work | CM Web Solutions | Portfolio">
    <Header />
    <main>
        <section class="section work-hero">
            <div class="work-bg"></div>
            <div class="container">
                <div class="work-hero-content">
                    <span class="eyebrow">Our work</span>
                    <h1>Real websites for real businesses.</h1>
                    <p class="lead">Every project is different, but our approach stays the same: understand the goal, design with purpose, and deliver something that works.</p>
                </div>
            </div>
        </section>

        <section class="section section-soft">
            <div class="container">
                <div class="work-filters">
                    <button class="filter-btn filter-btn--active">All</button>
                    <button class="filter-btn">Landing pages</button>
                    <button class="filter-btn">Business sites</button>
                    <button class="filter-btn">Integrations</button>
                </div>

                <div class="work-grid">
                    <article class="work-card">
                        <div class="work-thumb work-thumb--1">
                            <span class="work-label">Landing page</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Brighton Dental Studio</h2>
                            <p class="work-desc">A single-page lead generation site for a private dental practice. Clean, trustworthy design with a clear booking flow.</p>
                            <div class="work-tags">
                                <span class="work-tag">Design</span>
                                <span class="work-tag">Development</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--2">
                            <span class="work-label">Business site</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Thames Valley Plumbing</h2>
                            <p class="work-desc">A 5-page service site with contact form, service area map, and testimonial carousel.</p>
                            <div class="work-tags">
                                <span class="work-tag">Design</span>
                                <span class="work-tag">SEO</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--3">
                            <span class="work-label">E-commerce</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">The Urban Pantry</h2>
                            <p class="work-desc">A custom online store with product management, inventory tracking, and booking integration for local pickup.</p>
                            <div class="work-tags">
                                <span class="work-tag">Integrations</span>
                                <span class="work-tag">E-commerce</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--4">
                            <span class="work-label">Landing page</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Peak Fitness Coaching</h2>
                            <p class="work-desc">A high-converting landing page for paid ad campaigns. Optimised for speed and mobile-first browsing.</p>
                            <div class="work-tags">
                                <span class="work-tag">Design</span>
                                <span class="work-tag">Performance</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--5">
                            <span class="work-label">Multi-page</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Charterhouse Accountants</h2>
                            <p class="work-desc">A 10-page professional services site with secure client portal integration and CRM syncing.</p>
                            <div class="work-tags">
                                <span class="work-tag">Integrations</span>
                                <span class="work-tag">Design</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--6">
                            <span class="work-label">Full stack</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Nourish Meal Prep</h2>
                            <p class="work-desc">A subscription-based meal prep service with ordering system, customer dashboard, and CRM sync.</p>
                            <div class="work-tags">
                                <span class="work-tag">Full stack</span>
                                <span class="work-tag">Integrations</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--1">
                            <span class="work-label">Landing page</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">The London Barber Co.</h2>
                            <p class="work-desc">A sleek landing page with integrated booking widget and Google Maps location embed.</p>
                            <div class="work-tags">
                                <span class="work-tag">Design</span>
                                <span class="work-tag">Integrations</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--4">
                            <span class="work-label">Business site</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">ClearView Windows</h2>
                            <p class="work-desc">A 5-page site with quote request form, gallery, and service area coverage checker.</p>
                            <div class="work-tags">
                                <span class="work-tag">Design</span>
                                <span class="work-tag">SEO</span>
                            </div>
                        </div>
                    </article>

                    <article class="work-card">
                        <div class="work-thumb work-thumb--5">
                            <span class="work-label">Multi-page</span>
                        </div>
                        <div class="work-info">
                            <h2 class="work-title">Haven Interiors</h2>
                            <p class="work-desc">A full portfolio site for an interior design studio with project galleries and enquiry forms.</p>
                            <div class="work-tags">
                                <span class="work-tag">Design</span>
                                <span class="work-tag">Development</span>
                            </div>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <CTA />
    </main>
    <Footer />
</Layout>

<style>
    .work-hero {
        position: relative;
        padding: 144px 0 100px;
        color: var(--white);
        overflow: hidden;
    }

    .work-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 20%, rgba(65, 0, 245, 0.3) 0%, transparent 100%),
                    radial-gradient(ellipse 60% 50% at 80% 80%, rgba(15, 210, 187, 0.12) 0%, transparent 100%),
                    var(--black);
        z-index: 0;
    }

    .work-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(252, 252, 252, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(252, 252, 252, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
    }

    .work-hero-content {
        position: relative;
        z-index: 1;
        max-width: 640px;
    }

    .work-hero-content h1 {
        color: var(--white);
    }

    .work-hero-content :global(.lead) {
        color: var(--dark-muted);
    }

    .work-hero-content :global(.eyebrow) {
        color: var(--accent);
        background: rgba(15, 210, 187, 0.1);
        border-color: rgba(15, 210, 187, 0.2);
    }

    .work-hero-content :global(.eyebrow)::before {
        background: var(--accent);
        box-shadow: 0 0 0 5px rgba(15, 210, 187, 0.18);
    }

    .work-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 40px;
    }

    .filter-btn {
        padding: 8px 18px;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: var(--surface);
        font-size: 0.88rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 180ms ease;
        color: var(--muted);
    }

    .filter-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
    }

    .filter-btn--active {
        background: var(--primary);
        color: var(--white);
        border-color: var(--primary);
    }

    .work-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
    }

    .work-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        overflow: hidden;
        transition: transform 240ms ease, box-shadow 240ms ease;
    }

    .work-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-card);
    }

    .work-thumb {
        position: relative;
        height: 220px;
        display: flex;
        align-items: flex-start;
        justify-content: flex-end;
        padding: 18px;
    }

    .work-thumb--1 { background: linear-gradient(135deg, #4100F5, #7B4AFF); }
    .work-thumb--2 { background: linear-gradient(135deg, #0FD2BB, #0AA8D2); }
    .work-thumb--3 { background: linear-gradient(135deg, #FF6B6B, #EE5A24); }
    .work-thumb--4 { background: linear-gradient(135deg, #6C5CE7, #A29BFE); }
    .work-thumb--5 { background: linear-gradient(135deg, #1B1919, #444); }
    .work-thumb--6 { background: linear-gradient(135deg, #00B894, #00CEC9); }

    .work-label {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
        color: var(--white);
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .work-info {
        padding: 22px 24px 24px;
    }

    .work-title {
        font-size: 1.15rem;
        font-weight: 800;
        line-height: 1.08;
        margin-bottom: 8px;
    }

    .work-desc {
        font-size: 0.9rem;
        color: var(--muted);
    }

    .work-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 14px;
    }

    .work-tag {
        font-size: 0.76rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
        color: var(--primary);
        background: rgba(65, 0, 245, 0.08);
    }

    @media (max-width: 980px) {
        .work-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .work-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
